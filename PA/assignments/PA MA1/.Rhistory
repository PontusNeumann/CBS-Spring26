plot.subtitle    = element_text(color = bene[2]),
panel.grid.minor = element_blank(),
legend.position  = "bottom",
strip.text       = element_text(face = "bold")
)
data <- as.data.frame(olympic_running)
fits <- data %>%
group_by(Length, Sex) %>%
filter(!is.na(Time)) %>%
summarise(
slope = coef(lm(Time ~ Year))[2],
.groups = "drop"
)
fits_tbl <- fits %>%
mutate(`Avg. change per year (sec)` = sprintf("%.4f", slope)) %>%
select(Event = Length, Sex, `Avg. change per year (sec)`)
knitr::kable(
