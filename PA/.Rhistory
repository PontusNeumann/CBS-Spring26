# Chunk 1: setup
knitr::opts_chunk$set(echo = TRUE, warning = FALSE, message = FALSE)
# Chunk 2: load-data
data("USMacroG", package = "AER")
gdp <- USMacroG[, "gdp"]
# Chunk 3: gdp-plot
plot(gdp, main = "US Real GDP (1950–2000)", ylab = "Billion USD", xlab = "Year")
# Chunk 4: gdp-acf
acf(gdp, main = "ACF of US Real GDP")
# Chunk 5: gdp-growth
gdp_growth <- diff(log(gdp)) * 100  # Quarter-on-quarter log growth rate in %
# Chunk 6: growth-plot
plot(gdp_growth,
main = "US Real GDP Growth Rate (QoQ)",
ylab = "Growth Rate (%)",
xlab = "Year")
# Chunk 7: growth-acf
acf(gdp_growth, main = "ACF of GDP Growth Rate")
# Chunk 8: ljung-box
Box.test(gdp_growth, lag = 12, type = "Ljung-Box")
